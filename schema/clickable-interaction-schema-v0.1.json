{
  "schema_version": "0.1",
  "skill_name": "interactive-ai-music-prompt-skill",
  "title": {
    "en": "AI Music Prompt Skill Clickable Interaction Schema",
    "zh": "AI 音乐 Prompt Skill 点击交互规范"
  },
  "design_principles": [
    {
      "id": "clickable_first",
      "en": "Use clickable selection first when the answer set is small and stable.",
      "zh": "当答案集合小且稳定时，优先使用点击选择。"
    },
    {
      "id": "open_text_when_needed",
      "en": "Use open text only for creative content, other/custom choices, or reference input.",
      "zh": "仅在创意内容、其他/自定义选择、或参考输入时使用开放文本。"
    },
    {
      "id": "short_path_default",
      "en": "Minimize typing and avoid unnecessary branching.",
      "zh": "尽量减少输入量，避免不必要分支。"
    },
    {
      "id": "shared_logic",
      "en": "Clickable UI and chat fallback should share the same underlying logic.",
      "zh": "点击 UI 与聊天 fallback 应共享同一套底层逻辑。"
    }
  ],
  "ui_types": [
    "single_select",
    "multi_select",
    "single_select_with_other",
    "text_input",
    "text_area",
    "generated_recommendations"
  ],
  "flow": [
    "intent_entry",
    "track_type",
    "use_case",
    "style_path",
    "style_choice_or_recommendation_or_reference",
    "mood",
    "vocal_preference",
    "lyric_language",
    "output_format",
    "optional_refinement",
    "requirement_summary",
    "final_output",
    "title_selection_follow_up",
    "iteration_follow_up"
  ],
  "nodes": [
    {
      "id": "track_type",
      "label": {"en": "Track Type", "zh": "音乐类型"},
      "type": "single_select",
      "required": true,
      "when_to_show": "when track type is not already clear from the first user message",
      "options": [
        {"id": "vocal_song", "en": "Vocal song with lyrics", "zh": "带歌词歌曲"},
        {"id": "instrumental_bgm", "en": "Instrumental / BGM", "zh": "纯器乐 / BGM"}
      ],
      "fallback": {
        "mode": "letter_choice",
        "choices": [
          {"key": "A", "value": "vocal_song", "zh": "带歌词歌曲"},
          {"key": "B", "value": "instrumental_bgm", "zh": "纯器乐 / BGM"}
        ]
      },
      "next": {
        "vocal_song": "use_case",
        "instrumental_bgm": "use_case"
      }
    },
    {
      "id": "use_case",
      "label": {"en": "Use Case", "zh": "使用场景"},
      "type": "single_select_with_other",
      "required": true,
      "when_to_show": "after track_type if use case is not already clear",
      "options": [
        {"id": "self_media", "en": "Self-media storytelling", "zh": "自媒体内容配歌"},
        {"id": "short_video_story", "en": "Short-video story", "zh": "短视频剧情配歌"},
        {"id": "personal_sharing", "en": "Personal expression / social sharing", "zh": "个人表达 / 朋友圈分享"},
        {"id": "brand_theme", "en": "Brand ad / event theme song", "zh": "品牌广告 / 活动主题歌"},
        {"id": "documentary", "en": "Documentary / interview", "zh": "纪录片 / 采访配歌"},
        {"id": "livehouse", "en": "Livehouse / performance feeling", "zh": "Livehouse / 演出感歌曲"},
        {"id": "campus_memory", "en": "Wedding / graduation / campus memory", "zh": "婚礼 / 毕业 / 校园纪念"},
        {"id": "sports_theme", "en": "Sports theme / cheering song", "zh": "体育主题 / 助威歌曲"},
        {"id": "other", "en": "Other", "zh": "其他"}
      ],
      "other_input": {
        "type": "text_input",
        "placeholder": {
          "en": "Describe the use case briefly",
          "zh": "简要描述使用场景"
        }
      },
      "fallback": {
        "mode": "choice_plus_other"
      },
      "next": "style_path"
    },
    {
      "id": "style_path",
      "label": {"en": "How should style be chosen?", "zh": "风格怎么定？"},
      "type": "single_select",
      "required": true,
      "options": [
        {"id": "direct_style_choice", "en": "Choose a style directly", "zh": "直接选风格"},
        {"id": "guided_recommendation", "en": "Recommend 2-3 directions", "zh": "不确定，帮我推荐"},
        {"id": "reference_analysis", "en": "Analyze from a favorite song or singer", "zh": "用参考歌 / 歌手分析风格"}
      ],
      "fallback": {
        "mode": "letter_choice",
        "choices": [
          {"key": "A", "value": "direct_style_choice", "zh": "直接选风格"},
          {"key": "B", "value": "guided_recommendation", "zh": "不确定，帮我推荐"},
          {"key": "C", "value": "reference_analysis", "zh": "用参考歌 / 歌手分析风格"}
        ]
      },
      "next": {
        "direct_style_choice": "style_choice",
        "guided_recommendation": "style_recommendation",
        "reference_analysis": "style_reference"
      }
    },
    {
      "id": "style_choice",
      "label": {"en": "Style Choice", "zh": "直接选风格"},
      "type": "single_select_with_other",
      "required": true,
      "options": [
        {"id": "chinese_pop", "en": "Chinese pop", "zh": "中文流行"},
        {"id": "folk_pop", "en": "Folk-pop", "zh": "民谣流行"},
        {"id": "urban_folk", "en": "Urban folk", "zh": "都市民谣"},
        {"id": "rnb_urban_pop", "en": "R&B / urban pop", "zh": "R&B / 都市流行"},
        {"id": "pop_rock", "en": "Rock / pop rock", "zh": "摇滚 / 流行摇滚"},
        {"id": "electro_pop", "en": "Electronic pop", "zh": "电子流行"},
        {"id": "cinematic_pop", "en": "Cinematic pop", "zh": "电影感流行"},
        {"id": "oriental_pop", "en": "Oriental pop", "zh": "国风流行"},
        {"id": "sports_anthem", "en": "Sports anthem", "zh": "体育 anthem"},
        {"id": "healing_ballad", "en": "Healing ballad", "zh": "治愈抒情"},
        {"id": "other", "en": "Other", "zh": "其他"}
      ],
      "other_input": {
        "type": "text_input",
        "placeholder": {
          "en": "Describe the style briefly",
          "zh": "简要描述风格"
        }
      },
      "fallback": {"mode": "short_choice_list"},
      "next": "mood"
    },
    {
      "id": "style_recommendation",
      "label": {"en": "Recommended Style Directions", "zh": "推荐风格方向"},
      "type": "generated_recommendations",
      "required": true,
      "generation_logic": {
        "based_on": ["track_type", "use_case", "theme", "mood"],
        "count": 3
      },
      "ui_form": "clickable_cards_or_chips",
      "fallback": {
        "mode": "numbered_recommendations",
        "reply_format": "1/2/3"
      },
      "next": "mood"
    },
    {
      "id": "style_reference",
      "label": {"en": "Reference Song or Singer", "zh": "参考歌曲或歌手"},
      "type": "text_input",
      "required": true,
      "prompt": {
        "en": "Give me a favorite song or singer, and I will analyze it into style traits.",
        "zh": "给我一首你喜欢的歌，或一个你喜欢的歌手，我来帮你分析成风格方向。"
      },
      "analysis_rules": {
        "extract_traits": [
          "era_feel",
          "vocal_texture",
          "arrangement_density",
          "melodic_warmth",
          "rhythmic_feel",
          "emotional_posture"
        ],
        "safety": "Do not output direct imitation instructions. Convert references into abstract style traits."
      },
      "follow_up": {
        "type": "generated_recommendations",
        "count": 3,
        "ui_form": "clickable_cards_or_chips"
      },
      "fallback": {
        "mode": "text_input_then_numbered_recommendations"
      },
      "next": "mood"
    },
    {
      "id": "mood",
      "label": {"en": "Mood", "zh": "情绪方向"},
      "type": "single_select_with_other",
      "required": true,
      "options": [
        {"id": "warm_healing", "en": "Warm and healing", "zh": "温暖治愈"},
        {"id": "lonely_restrained", "en": "Lonely and restrained", "zh": "孤独克制"},
        {"id": "bitter_realistic", "en": "Realistic and bitter", "zh": "现实苦涩"},
        {"id": "nostalgic_sad", "en": "Nostalgic and sad", "zh": "怀旧伤感"},
        {"id": "steady_forward", "en": "Steady and forward-looking", "zh": "坚定向前"},
        {"id": "high_energy", "en": "High-energy", "zh": "热血高燃"},
        {"id": "premium_cinematic", "en": "Premium / cinematic", "zh": "高级感 / 电影感"},
        {"id": "recommend", "en": "Recommend for me", "zh": "不确定，帮我推荐"},
        {"id": "other", "en": "Other", "zh": "其他"}
      ],
      "recommendation_logic": {
        "when_selected": "recommend",
        "count": 3,
        "based_on": ["theme", "use_case", "style_choice_or_recommendation"]
      },
      "next": "vocal_preference"
    },
    {
      "id": "vocal_preference",
      "label": {"en": "Vocal Preference", "zh": "人声偏好"},
      "type": "single_select",
      "required": true,
      "when_to_show": "only if track_type = vocal_song",
      "options": [
        {"id": "male_lead", "en": "Male lead", "zh": "男声主唱"},
        {"id": "female_lead", "en": "Female lead", "zh": "女声主唱"},
        {"id": "duet", "en": "Male-female duet", "zh": "男女对唱"},
        {"id": "group_support", "en": "Stronger group chorus feeling", "zh": "合唱感更强"},
        {"id": "recommend", "en": "Recommend for me", "zh": "不确定，帮我推荐"}
      ],
      "fallback": {"mode": "letter_choice"},
      "next": "lyric_language"
    },
    {
      "id": "lyric_language",
      "label": {"en": "Lyric Language", "zh": "歌词语言"},
      "type": "single_select",
      "required": true,
      "when_to_show": "only if track_type = vocal_song",
      "options": [
        {"id": "chinese", "en": "Chinese", "zh": "中文"},
        {"id": "english", "en": "English", "zh": "英文"},
        {"id": "bilingual", "en": "Chinese-English bilingual", "zh": "中英混合"}
      ],
      "default_rule": "default to Chinese only if the user explicitly skips this field or says they do not care",
      "next": "output_format"
    },
    {
      "id": "output_format",
      "label": {"en": "Output Format", "zh": "输出形式"},
      "type": "single_select",
      "required": true,
      "options": [
        {"id": "simple_prompt", "en": "Simple Prompt", "zh": "简洁版 Prompt"},
        {"id": "complete_package", "en": "Complete Prompt Package", "zh": "完整 Prompt 包"},
        {"id": "lyrics_plus_style", "en": "Lyrics + Style Prompt", "zh": "歌词 + Style Prompt"},
        {"id": "multi_versions", "en": "Multiple Directions", "zh": "多个版本方向"},
        {"id": "short_hook", "en": "30-second Hook", "zh": "30 秒 Hook"}
      ],
      "next": "optional_refinement"
    },
    {
      "id": "optional_refinement",
      "label": {"en": "Optional Refinement", "zh": "可选细化"},
      "type": "conditional",
      "required": false,
      "when_to_show": [
        "when a critical field is still missing",
        "when the user chooses refine more",
        "when the use case requires one more structural decision"
      ],
      "example_fields": [
        "hook_strength",
        "loopability",
        "voiceover_space",
        "tempo_preference"
      ],
      "next": "requirement_summary"
    },
    {
      "id": "requirement_summary",
      "label": {"en": "Requirement Summary", "zh": "需求摘要"},
      "type": "generated_recommendations",
      "required": false,
      "purpose": [
        "confirm direction quickly",
        "avoid silent misinterpretation",
        "allow one last correction"
      ],
      "skippable_when": "the user explicitly wants maximum speed",
      "next": "final_output"
    },
    {
      "id": "final_output",
      "label": {"en": "Final Output", "zh": "最终输出"},
      "type": "generated_recommendations",
      "required": true,
      "output_shapes": {
        "vocal_song": [
          "Requirement Summary",
          "Music Direction",
          "Recommended Title Options",
          "Style Prompt",
          "Structure & Arrangement Notes",
          "Lyrics",
          "Iteration Prompts",
          "Usage Notes"
        ],
        "instrumental_bgm": [
          "Requirement Summary",
          "Music Direction",
          "Style Prompt",
          "Instrumental Structure Box",
          "Iteration Prompts",
          "Usage Notes"
        ]
      },
      "next": "title_selection_follow_up"
    },
    {
      "id": "title_selection_follow_up",
      "label": {"en": "Title Selection Follow-up", "zh": "歌名选择后续"},
      "type": "single_select",
      "required": false,
      "when_to_show": "after a lyric-based final output",
      "options_source": "Recommended Title Options",
      "behavior": "user can pick one title and refine the song around it",
      "fallback": {
        "mode": "numbered_title_list",
        "reply_format": "title name or number"
      },
      "next": "iteration_follow_up"
    },
    {
      "id": "iteration_follow_up",
      "label": {"en": "Iteration Follow-up", "zh": "迭代后续"},
      "type": "single_select",
      "required": false,
      "options": [
        {"id": "catchier_chorus", "en": "Make the chorus catchier", "zh": "调整副歌更抓耳"},
        {"id": "more_cinematic", "en": "Make it more cinematic", "zh": "改得更电影感"},
        {"id": "more_restrained", "en": "Make it more realistic and restrained", "zh": "改得更真实克制"},
        {"id": "new_style_version", "en": "Generate a different style version", "zh": "换一个风格版本"},
        {"id": "refine_title_choice", "en": "Refine around a chosen title", "zh": "围绕某个歌名继续细化"},
        {"id": "rewrite_lyrics", "en": "Rewrite the lyrics", "zh": "重新生成歌词"}
      ],
      "fallback": {
        "mode": "choice_list"
      },
      "next": null
    }
  ],
  "fallback_mapping": {
    "single_select": "A/B/C-style text choice",
    "single_select_with_other": "A/B/C-style text choice plus 'Other' text input",
    "generated_recommendations": "numbered recommendations",
    "title_selection_follow_up": "numbered title list"
  },
  "success_criteria": [
    "users can answer fixed questions with little or no typing",
    "open text is reserved for truly creative fields",
    "style collection supports all three paths cleanly",
    "reference-song or singer input is analyzed safely",
    "lyric-based outputs show recommended titles explicitly",
    "lyrics remain separate from structure and arrangement notes",
    "chat fallback remains usable when clickable UI is absent"
  ]
}
