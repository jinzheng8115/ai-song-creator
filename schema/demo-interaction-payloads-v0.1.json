{
  "version": "0.1",
  "description": {
    "en": "Demo interaction payloads for clickable AI music prompt skill flows.",
    "zh": "AI 音乐 Prompt Skill 点击交互流程示例 payload。"
  },
  "examples": [
    {
      "id": "workplace_women_song",
      "title": {
        "en": "Workplace women song flow",
        "zh": "职场女性歌曲流程"
      },
      "user_opening_message": "创作一首关于职场女性的歌曲",
      "expected_mode": "create_vocal_song",
      "steps": [
        {
          "step": 1,
          "node_id": "track_type",
          "ui_type": "single_select",
          "prompt": {
            "zh": "先选音乐类型",
            "en": "Choose track type"
          },
          "options": [
            {"id": "vocal_song", "label": "带歌词歌曲"},
            {"id": "instrumental_bgm", "label": "纯器乐 / BGM"}
          ],
          "user_selection": "vocal_song",
          "result": {
            "zh": "用户选择：带歌词歌曲",
            "en": "User selected: Vocal song with lyrics"
          }
        },
        {
          "step": 2,
          "node_id": "use_case",
          "ui_type": "single_select_with_other",
          "prompt": {
            "zh": "这首歌主要用在什么场景？",
            "en": "Where will this song be used?"
          },
          "options": [
            "自媒体内容配歌",
            "短视频剧情配歌",
            "个人表达 / 朋友圈分享",
            "品牌广告 / 活动主题歌",
            "纪录片 / 采访配歌",
            "其他"
          ],
          "user_selection": "自媒体内容配歌",
          "result": {
            "zh": "系统记录 use_case = self_media",
            "en": "System records use_case = self_media"
          }
        },
        {
          "step": 3,
          "node_id": "style_path",
          "ui_type": "single_select",
          "prompt": {
            "zh": "风格怎么定？",
            "en": "How should style be chosen?"
          },
          "options": [
            "直接选风格",
            "不确定，帮我推荐",
            "用参考歌 / 歌手分析风格"
          ],
          "user_selection": "不确定，帮我推荐",
          "result": {
            "zh": "进入系统推荐风格路径",
            "en": "Enter guided style recommendation path"
          }
        },
        {
          "step": 4,
          "node_id": "style_recommendation",
          "ui_type": "generated_recommendations",
          "generation_basis": [
            "theme = 职场女性",
            "use_case = 自媒体内容配歌",
            "track_type = vocal_song"
          ],
          "recommended_options": [
            {
              "id": "urban_pop_narrative",
              "label": {
                "zh": "都市叙事流行：更适合表达职场压力、独立与自我拉扯",
                "en": "Urban narrative pop: good for pressure, independence, and inner conflict"
              }
            },
            {
              "id": "rnb_urban_feminine",
              "label": {
                "zh": "都市感 R&B / pop：更现代、更有女性自我意识",
                "en": "Urban R&B / pop: more modern and self-aware"
              }
            },
            {
              "id": "cinematic_growth_ballad",
              "label": {
                "zh": "电影感成长抒情：更高级、更适合人物故事型内容",
                "en": "Cinematic growth ballad: more elevated and story-driven"
              }
            }
          ],
          "user_selection": "urban_pop_narrative",
          "result": {
            "zh": "系统记录 style = 都市叙事流行",
            "en": "System records style = urban narrative pop"
          }
        },
        {
          "step": 5,
          "node_id": "mood",
          "ui_type": "single_select_with_other",
          "prompt": {
            "zh": "想要什么情绪方向？",
            "en": "What mood direction do you want?"
          },
          "options": [
            "温暖治愈",
            "孤独克制",
            "现实苦涩",
            "坚定向前",
            "高级感 / 电影感",
            "其他"
          ],
          "user_selection": "坚定向前",
          "result": {
            "zh": "系统记录 mood = steady_forward",
            "en": "System records mood = steady_forward"
          }
        },
        {
          "step": 6,
          "node_id": "vocal_preference",
          "ui_type": "single_select",
          "prompt": {
            "zh": "人声方向",
            "en": "Vocal preference"
          },
          "options": [
            "男声主唱",
            "女声主唱",
            "男女对唱",
            "合唱感更强",
            "不确定，帮我推荐"
          ],
          "user_selection": "女声主唱",
          "result": {
            "zh": "系统记录 vocal = female_lead",
            "en": "System records vocal = female_lead"
          }
        },
        {
          "step": 7,
          "node_id": "lyric_language",
          "ui_type": "single_select",
          "prompt": {
            "zh": "歌词语言",
            "en": "Lyric language"
          },
          "options": [
            "中文",
            "英文",
            "中英混合"
          ],
          "user_selection": "中文",
          "result": {
            "zh": "系统记录 lyrics = Chinese",
            "en": "System records lyrics = Chinese"
          }
        },
        {
          "step": 8,
          "node_id": "output_format",
          "ui_type": "single_select",
          "prompt": {
            "zh": "输出形式",
            "en": "Output format"
          },
          "options": [
            "简洁版 Prompt",
            "完整 Prompt 包",
            "歌词 + Style Prompt",
            "多个版本方向"
          ],
          "user_selection": "完整 Prompt 包",
          "result": {
            "zh": "系统记录 output = complete_package",
            "en": "System records output = complete_package"
          }
        },
        {
          "step": 9,
          "node_id": "requirement_summary",
          "ui_type": "generated_recommendations",
          "summary": {
            "zh": [
              "类型：带歌词歌曲",
              "场景：自媒体内容配歌",
              "风格：都市叙事流行",
              "情绪：坚定向前",
              "人声：女声主唱",
              "歌词语言：中文",
              "输出：完整 Prompt 包"
            ],
            "en": [
              "Track type: Vocal song",
              "Use case: Self-media storytelling",
              "Style: Urban narrative pop",
              "Mood: Steady and forward-looking",
              "Vocal: Female lead",
              "Lyrics: Chinese",
              "Output: Complete package"
            ]
          }
        },
        {
          "step": 10,
          "node_id": "final_output",
          "ui_type": "generated_recommendations",
          "expected_blocks": [
            "Requirement Summary",
            "Music Direction",
            "Recommended Title Options",
            "Style Prompt",
            "Structure & Arrangement Notes",
            "Lyrics",
            "Iteration Prompts",
            "Usage Notes"
          ]
        },
        {
          "step": 11,
          "node_id": "title_selection_follow_up",
          "ui_type": "single_select",
          "prompt": {
            "zh": "选择一个推荐歌名，继续细化",
            "en": "Choose a recommended title to refine further"
          },
          "example_title_options": [
            "她还在往前走",
            "写字楼的灯",
            "不肯退的人",
            "把自己撑住"
          ],
          "user_selection": "她还在往前走"
        },
        {
          "step": 12,
          "node_id": "iteration_follow_up",
          "ui_type": "single_select",
          "options": [
            "调整副歌更抓耳",
            "改得更电影感",
            "改得更真实克制",
            "围绕某个歌名继续细化"
          ],
          "user_selection": "改得更真实克制"
        }
      ]
    },
